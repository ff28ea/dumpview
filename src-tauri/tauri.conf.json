{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "dumpview",
  "version": "0.1.1",
  "identifier": "io.github.ff28ea.dumpview",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run frontend:dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "dumpview",
        "width": 1480,
        "height": 920,
        "minWidth": 980,
        "minHeight": 720,
        "decorations": false,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
